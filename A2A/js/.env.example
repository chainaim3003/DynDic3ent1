# ── Gemini API (required) ───────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey  (starts with AIza...)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Model selection per tier (defaults shown) ───────────────────────────────
# Pro    = used for seller + buyer main negotiation decisions
# Flash  = used for treasury and any future routing / sub-agent advisories
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_FLASH_MODEL=gemini-2.5-flash

# ── Cost-control override (leave blank for normal tier-based selection) ─────
# If set, ALL LLM calls use this model regardless of tier. Useful for dev runs
# where you want everything on the cheapest model. Example:
#   GEMINI_FORCE_MODEL=gemini-2.5-flash-lite
GEMINI_FORCE_MODEL=

# ── Per-negotiation token ceiling (safety) ──────────────────────────────────
PER_NEGOTIATION_TOKEN_CEILING=20000

# ── Retry behavior on 429s ──────────────────────────────────────────────────
GEMINI_MAX_RETRIES=3

# ─────────────────────────────────────────────────────────────────────────────
# ITERATION 1 — IDENTITY + COMPLIANCE
# ─────────────────────────────────────────────────────────────────────────────

# Mode selection for the CredentialProvider. Two valid values:
#   plain  — agent card + real GLEIF check. No KERI/vLEI required. (default)
#   vlei   — all of plain PLUS KERI delegation chain via legentvLEI port 4000.
# Anything else logs a warning and falls back to plain.
CREDENTIAL_MODE=plain

# ── Agent card directories ──────────────────────────────────────────────────
# live-agent-cards/  customer-onboarded cards (gitignored)
# demo-agent-cards/  source-controlled demo cards
# Override if you want a non-default location.
# LIVE_AGENT_CARDS_DIR=./live-agent-cards
# DEMO_AGENT_CARDS_DIR=./demo-agent-cards

# ── GLEIF API (real, no mocks) ──────────────────────────────────────────────
GLEIF_API_URL=https://api.gleif.org/api/v1
GLEIF_TIMEOUT_MS=8000

# Re-check LEI status on EVERY negotiation start? (default true)
# Set false to use the cache only (cheaper, less defensive).
GLEIF_RECHECK_AT_NEGOTIATION=true

# Cache TTL in hours (default 24)
GLEIF_CACHE_TTL_HOURS=24

# Optional sanctions list — ISO 3166-1 alpha-2 codes, comma-separated.
# When set, an LEI registered in any listed country fails compliance.
# SANCTIONED_COUNTRIES=KP,IR,SY,RU

# ── Onboarding API server port ──────────────────────────────────────────────
ONBOARDING_PORT=6060
